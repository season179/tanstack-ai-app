# Chat is backed by OpenRouter (no AI SDK — we call the API directly).
OPENROUTER_API_KEY=
# Default chat model used when the composer's picker has no selection.
OPENROUTER_DEFAULT_MODEL=
# Optional: tool exposure mode. "search" (default) exposes only the
# tool_search / tool_describe / tool_call bridge; "all" exposes every tool.
TOOL_EXPOSURE_MODE=search
